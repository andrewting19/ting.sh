{
  "name": "ting.sh",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c cyan,magenta \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "AUTO_UPDATE=false bun run --hot server.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "bun run server.ts",
    "test": "bun test",
    "test:ui": "playwright test --ui",
    "release": "./scripts/release.sh",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
